    <script>
        // 1. Navigation System (SPA)
        function navigateTo(sectionId, elementId = null) {
            // Hide all sections
            document.querySelectorAll('.spa-section').forEach(section => {
                section.classList.remove('active');
            });
            
            // Show target section
            const target = document.getElementById(sectionId);
            if (target) {
                target.classList.add('active');
                window.scrollTo(0, 0);
                
                // Active menu link highlight
                document.querySelectorAll('.nav-link').forEach(link => {
                    link.classList.remove('active');
                    if(link.getAttribute('onclick')?.includes(sectionId)) link.classList.add('active');
                });
            }

            // Sub-element scroll (e.g., mission/team)
            if (elementId) {
                setTimeout(() => {
                    const el = document.getElementById(elementId);
                    if (el) el.scrollIntoView({ behavior: 'smooth' });
                }, 100);
            }

            // Close mobile menu
            closeMobileMenu();
        }

        // 2. Mobile Menu Accordion
        const menuBtn = document.getElementById('menuBtn');
        const closeBtn = document.getElementById('closeBtn');
        const drawer = document.getElementById('drawer');
        const overlay = document.getElementById('overlay');

        menuBtn.onclick = () => {
            drawer.classList.add('open');
            overlay.classList.add('active');
        };

        function closeMobileMenu() {
            drawer.classList.remove('open');
            overlay.classList.remove('active');
        }

        closeBtn.onclick = closeMobileMenu;
        overlay.onclick = closeMobileMenu;

        document.querySelectorAll('.accordion-trigger').forEach(btn => {
            btn.onclick = function() {
                const submenu = this.nextElementSibling;
                const isOpen = this.classList.contains('open');
                
                // Close all others
                document.querySelectorAll('.accordion-trigger').forEach(el => {
                    el.classList.remove('open');
                    el.nextElementSibling.style.maxHeight = null;
                });

                if (!isOpen) {
                    this.classList.add('open');
                    submenu.style.maxHeight = submenu.scrollHeight + "px";
                }
            };
        });

        // 3. Header Scroll Effect
        window.onscroll = function() {
            const header = document.getElementById('main-header');
            const topBtn = document.getElementById('topBtn');
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
                topBtn.style.display = "flex";
            } else {
                header.classList.remove('scrolled');
                topBtn.style.display = "none";
            }
        };

        topBtn.onclick = () => window.scrollTo({top: 0, behavior: 'smooth'});

        // 4. Preloader
        window.onload = () => {
            setTimeout(() => {
                document.getElementById('preloader').style.display = 'none';
                reveal(); // Check animations on load
            }, 1000);
        };

        // 5. Intersection Observer for Scroll Animations
        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                var elementVisible = 150;
                if (elementTop < windowHeight - elementVisible) {
                    reveals[i].classList.add("active");
                }
            }
        }
        window.addEventListener("scroll", reveal);

        // 6. Doctor Modal
        const modal = document.getElementById('docModal');
        const closeModal = document.querySelector('.close-modal');

        function openDocModal(name, title, edu, bio, img) {
            const body = document.getElementById('docModalBody');
            body.innerHTML = `
                <img src="${img}" style="width: 150px; border-radius: 15px;">
                <div>
                    <h2 style="color: var(--primary);">${name}</h2>
                    <p style="font-weight: 600; color: var(--accent);">${title}</p>
                    <p style="font-size: 0.9rem; margin: 10px 0;"><strong>Education:</strong> ${edu}</p>
                    <p style="color: var(--grey);">${bio}</p>
                    <button onclick="navigateTo('appointment')" class="btn btn-blue" style="margin-top:20px; padding: 8px 20px;">Book with ${name}</button>
                </div>
            `;
            modal.style.display = 'flex';
        }

        closeModal.onclick = () => modal.style.display = 'none';
        window.onclick = (e) => { if(e.target == modal) modal.style.display = 'none'; };

        // 7. Appointment Submission
        document.getElementById('aptForm').onsubmit = function(e) {
            e.preventDefault();
            const name = document.getElementById('apt-name').value;
            // Simulated validation and save
            const aptData = {
                name: name,
                date: document.getElementById('apt-date').value,
                dept: document.getElementById('apt-dept').value
            };
            localStorage.setItem('last_appointment', JSON.stringify(aptData));
            
            alert(`Thank you, ${name}! Your appointment has been booked. Check your email for confirmation.`);
            this.reset();
        };

        // 8. Handle Back/Forward Browser buttons for SPA
        window.onpopstate = function(event) {
            const hash = window.location.hash.replace('#', '') || 'home';
            navigateTo(hash);
        };
    </script>
